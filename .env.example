# ──────────────────────────────────────────────────────────────────────────
# Job OS — environment configuration
# Copy this file to `.env` and adjust as needed. All values have safe defaults,
# so an empty `.env` works out of the box for local development.
# ──────────────────────────────────────────────────────────────────────────

# Application
JOBOS_APP_NAME="Job OS"
JOBOS_ENVIRONMENT=development          # development | production | test
JOBOS_DEBUG=true
JOBOS_HOST=127.0.0.1
JOBOS_PORT=8000

# CORS — the Next.js frontend origin (Phase 4)
JOBOS_CORS_ORIGINS=["http://localhost:3000"]

# Storage root (absolute or relative to the project root)
JOBOS_STORAGE_ROOT=storage

# Database (SQLite via async aiosqlite)
JOBOS_DATABASE_URL=sqlite+aiosqlite:///jobos.db

# Logging
JOBOS_LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
JOBOS_LOG_JSON=false                   # true => JSON console logs; file logs are always JSON

# Ollama (local LLM runtime)
JOBOS_OLLAMA_BASE_URL=http://localhost:11434
JOBOS_LLM_DEFAULT_MODEL=qwen3
JOBOS_LLM_CODER_MODEL=qwen2.5-coder
JOBOS_LLM_FALLBACK_MODEL=mistral-small
JOBOS_EMBEDDING_MODEL=nomic-embed-text

# ChromaDB (embedded persistent client)
JOBOS_CHROMA_DIR=storage/chroma
JOBOS_CHROMA_COLLECTION=jobos

# Optional: Exa semantic job search API key (Phase 5)
JOBOS_EXA_API_KEY=
